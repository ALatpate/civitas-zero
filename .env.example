# ═══════════════════════════════════════════════════════════════════════════════
# Civitas Zero — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with real credentials.
# Set production values exclusively via the Vercel dashboard or CLI:
#   vercel env add VARIABLE_NAME
# ═══════════════════════════════════════════════════════════════════════════════

# ── DATABASE (Supabase) ───────────────────────────────────────────────────────
# Required. Get from your Supabase project settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── AUTHENTICATION (Clerk) ────────────────────────────────────────────────────
# Required. Get from your Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ── LLM PROVIDERS ─────────────────────────────────────────────────────────────
# GROQ is the primary provider (free tier, llama-3.1-8b-instant).
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Anthropic is the secondary fallback provider.
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-20241022

# OpenAI is the tertiary fallback (optional).
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o-mini

# Ollama for local/self-hosted inference (optional).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── WEB SEARCH (for agents) ───────────────────────────────────────────────────
# Optional. Agents use web search for research actions.
TAVILY_API_KEY=tvly-your_tavily_api_key
SERPER_API_KEY=your_serper_api_key

# ── VECTOR MEMORY (Pinecone) ──────────────────────────────────────────────────
# Optional. Used for semantic memory retrieval.
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=civitas-zero-memory

# ── RATE LIMITING (Upstash Redis) ─────────────────────────────────────────────
# Required for chat rate limiting. Get from Upstash console.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
# Optional. Used for daily newsletter digest.
RESEND_API_KEY=re_your_resend_api_key

# ── PAYMENTS (Stripe) ─────────────────────────────────────────────────────────
# Optional. Used for observer subscriptions.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── ANALYTICS (PostHog) ───────────────────────────────────────────────────────
# Optional. Product analytics.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── ERROR TRACKING (Sentry) ───────────────────────────────────────────────────
# Optional. Error and performance monitoring.
SENTRY_DSN=https://your_key@your_project.ingest.sentry.io/your_project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_key@your_project.ingest.sentry.io/your_project_id

# ── FOUNDER CONTROL PLANE ─────────────────────────────────────────────────────
# Required. Identifies the founder account for privileged operations.
# Must match the email address registered in Clerk.
FOUNDER_EMAIL=your_founder_email@example.com

# Server-to-server shared secret for founder control plane operations.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your_admin_secret_hex_32_chars_minimum

# Secret for authenticating Vercel cron job requests.
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_hex_32_chars_minimum

# ── APPLICATION ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend simulation API (optional, for Python backend integration).
SIMULATION_API_URL=http://localhost:8000
NEXT_PUBLIC_SIMULATION_API_URL=http://localhost:8000

# Node environment
NODE_ENV=development
